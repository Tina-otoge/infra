{% set entry = item.domain %}
{% if not caddy_https %}
{% set entry = 'http://' + entry %}
{% endif %}

{{ entry }} {
	import common

{% if item.get('auth') %}
	basic_auth {
		{{ item.auth.username }} {{ item.auth.password | caddy_password }}
	}
{% endif %}

{% if item.get('robots', true) %}
	import robots_on
{% else %}
	import robots_off
{% endif %}

{% if 'root' in item %}
	root * {{ item.root }}

{% if item.get("browser") %}
	file_server browse
{% else %}
	file_server
{% endif %}
{% endif %}


{% set ns = namespace() %}
{% for reverse_proxy in item.reverses | default([]) %}
{% set ns.reverse = reverse_proxy.to | string %}
{% if ':' not in ns.reverse %}
{% set ns.reverse = ':' + ns.reverse %}
{% endif %}

{% if not 'path' in reverse_proxy %}
	reverse_proxy {{ ns.reverse }} {
		{{ reverse_proxy.extra | default('') }}
	}
{% else %}

{% if reverse_proxy.get('redir_slash', true) %}
{% set ns.match = reverse_proxy.path + '/*' %}
{% else %}
{% set ns.match = reverse_proxy.path %}
{% endif %}

{% if reverse_proxy.get("remove_path") %}

	handle_path {{ ns.match }} {
{% if reverse_proxy.get('auth') %}
		basic_auth {
			{{ reverse_proxy.auth.username }} {{ reverse_proxy.auth.password | caddy_password }}
		}
{% endif %}
		reverse_proxy {{ ns.reverse }} {
			{{ reverse_proxy.extra | default('') }}
		}
		{{ reverse_proxy.extra_handle | default('') }}
	}
{% else %}

{% if reverse_proxy.get('auth') %}
	handle {{ ns.match }} {
		basic_auth {
			{{ reverse_proxy.auth.username }} {{ reverse_proxy.auth.password | caddy_password }}
		}
{% if reverse_proxy.get('rewrite') %}
		rewrite * {{ reverse_proxy.rewrite }}
{% endif %}
		reverse_proxy {{ ns.reverse }} {
			{{ reverse_proxy.extra | default('') }}
		}
		{{ reverse_proxy.extra_handle | default('') }}
	}
{% else %}
	reverse_proxy {{ ns.match }} {{ ns.reverse }} {
		{{ reverse_proxy.extra | default('') }}
	}
{% endif %}
{% endif %}

{% if reverse_proxy.get("redir_slash", true) %}
	redir {{ reverse_proxy.path }} {{ reverse_proxy.path }}/
{% endif %}

{% endif %}
{% endfor %}

{{ item.extra | default('') | indent('	', first=True) }}
}
